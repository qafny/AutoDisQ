(* ===================================== *)
(* Ripple-Carry Adder (well-typed skeleton) *)
(* ===================================== *)

(* We just define a small, legal “MAJ/UMA-like” pattern on 3 qubits.
   You can later expand to true ripple-carry with indices and loops. *)

Definition a0 : var := 2000.
Definition b0 : var := 2001.
Definition c0 : var := 2002.

Definition MAJ_1 (a b c : var) : op_list :=
  [ OpAP (CAppU L (CU c (Num 0) (X b (Num 0))));
    OpAP (CAppU L (CU c (Num 0) (X a (Num 0))));
    OpAP (CAppU L (CU a (Num 0) (CU b (Num 0) (X c (Num 0)))))
  ].

Definition UMA_1 (a b c : var) : op_list :=
  [ OpAP (CAppU L (CU a (Num 0) (CU b (Num 0) (X c (Num 0)))));
    OpAP (CAppU L (CU c (Num 0) (X a (Num 0))));
    OpAP (CAppU L (CU a (Num 0) (X b (Num 0))))
  ].

Definition rippleCarrySeq : op_list :=
  (* allocate 3 qubits a0 b0 c0 *)
  [ OpAP (CNew a0 1);
    OpAP (CNew b0 1);
    OpAP (CNew c0 1)
  ] ++
  MAJ_1 a0 b0 c0 ++
  UMA_1 a0 b0 c0.

Definition ripple_dist : distributed_prog :=
  auto_disq_alg1_paper 2 2 rippleCarrySeq cfg6.

Compute fit ripple_dist.