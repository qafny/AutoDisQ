(* Small helpers for viewing results                            *)
(* ------------------------------------------------------------ *)

Definition cfg1 : config := [Memb 0 []; Memb 1 []].

Definition memb_procs (m : memb) : list process :=
  match m with
  | Memb _ ps => ps
  | LockMemb _ _ ps => ps
  end.

Fixpoint flatten_config (cfg : config) : list process :=
  match cfg with
  | [] => []
  | m :: tl => memb_procs m ++ flatten_config tl
  end.

(* Convert a list of cexp into a sequential process AP ... AP ... PNil *)
Fixpoint proc_of_cexps (xs : list cexp) : process :=
  match xs with
  | [] => PNil
  | a :: tl => AP a (proc_of_cexps tl)
  end.

