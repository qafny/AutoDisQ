Inductive term : Type :=
| T_metric  (k : metric_kind) (x : cvar)
| T_const   (c : R)
| T_plus    (t1 t2 : term)
| T_minus   (t1 t2 : term)
| T_scale   (r : R) (t : term).

Inductive atom : Type :=
| A_le (t1 t2 : term)
| A_lt (t1 t2 : term)
| A_eq (t1 t2 : term)
| A_gap_le (t1 t2 : term) (eps : R).

Inductive formula : Type :=
| F_true
| F_atom (a : atom)
| F_not  (ψ : formula)
| F_and  (ψ χ : formula)
| F_or   (ψ χ : formula)
| F_impl (ψ χ : formula)
| F_forall (x : cvar) (ψ : formula)
| F_exists (x : cvar) (ψ : formula)
| F_X (ψ : formula)
| F_G (ψ : formula)
| F_F (ψ : formula)
| F_U (ψ χ : formula).
From Coq Require Import Reals List Arith Lia.
Import ListNotations.
Open Scope R_scope.

From FFVLCheck.src Require Import Base Metrics FKS FFVL_Syntax.

Definition env := cvar -> client.
Definition env_set (ρ:env) (x:cvar) (c:client) : env :=
  fun y => if Nat.eqb y x then c else ρ y.
Definition env_get (ρ:env) (x:cvar) : client := ρ x.

Fixpoint eval_term (K:FKS_trace) (ρ:env) (t:round) (e:term) : option R :=
  match e with
  | T_metric k x =>
      metric_at (τ K) t (env_get ρ x) k
  | T_const c => Some c
  | T_plus a b =>
      match eval_term K ρ t a, eval_term K ρ t b with
      | Some va, Some vb => Some (va + vb)
      | _, _ => None
      end
  | T_minus a b =>
      match eval_term K ρ t a, eval_term K ρ t b with
      | Some va, Some vb => Some (va - vb)
      | _, _ => None
      end
  | T_scale r a =>
      match eval_term K ρ t a with
      | Some va => Some (r * va)
      | None => None
      end
  end.

Definition eval_atom (K:FKS_trace) (ρ:env) (t:round) (a:atom) : option bool :=
  let cmp_le x y := if Rle_dec x y then true else false in
  let cmp_lt x y := if Rlt_dec x y then true else false in
  match a with
  | A_le e1 e2 =>
      match eval_term K ρ t e1, eval_term K ρ t e2 with
      | Some v1, Some v2 => Some (cmp_le v1 v2)
      | _, _ => None
      end
  | A_lt e1 e2 =>
      match eval_term K ρ t e1, eval_term K ρ t e2 with
      | Some v1, Some v2 => Some (cmp_lt v1 v2)
      | _, _ => None
      end
  | A_eq e1 e2 =>
      match eval_term K ρ t e1, eval_term K ρ t e2 with
      | Some v1, Some v2 => Some (if Req_dec v1 v2 then true else false)
      | _, _ => None
      end
  | A_gap_le e1 e2 eps =>
      match eval_term K ρ t e1, eval_term K ρ t e2 with
      | Some v1, Some v2 =>
          let d := Rabs (v1 - v2) in
          Some (cmp_le d eps)
      | _, _ => None
      end
  end.

(* bounded temporal semantics on finite trace:
   - X φ at t requires t+1 < T
   - G φ means for all m in [t..T-1]
   - F φ means exists m in [t..T-1]
   - U is bounded similarly
*)
Fixpoint sat (K:FKS_trace) (ρ:env) (t:round) (φ:formula) : option bool :=
  match φ with
  | F_true => Some true
  | F_atom a => eval_atom K ρ t a
  | F_not ψ =>
      match sat K ρ t ψ with
      | Some b => Some (negb b)
      | None => None
      end
  | F_and ψ χ =>
      match sat K ρ t ψ, sat K ρ t χ with
      | Some b1, Some b2 => Some (andb b1 b2)
      | _, _ => None
      end
  | F_or ψ χ =>
      match sat K ρ t ψ, sat K ρ t χ with
      | Some b1, Some b2 => Some (orb b1 b2)
      | _, _ => None
      end
  | F_impl ψ χ =>
      match sat K ρ t ψ, sat K ρ t χ with
      | Some b1, Some b2 => Some (orb (negb b1) b2)
      | _, _ => None
      end
  | F_forall x ψ =>
      (* iterate over clients in Cset *)
      let fix all_clients (cs:list client) :=
        match cs with
        | [] => Some true
        | c::tl =>
            match sat K (env_set ρ x c) t ψ, all_clients tl with
            | Some b1, Some b2 => Some (andb b1 b2)
            | _, _ => None
            end
        end
      in all_clients (Cset K)
  | F_exists x ψ =>
      let fix any_clients (cs:list client) :=
        match cs with
        | [] => Some false
        | c::tl =>
            match sat K (env_set ρ x c) t ψ, any_clients tl with
            | Some b1, Some b2 => Some (orb b1 b2)
            | _, _ => None
            end
        end
      in any_clients (Cset K)
  | F_X ψ =>
      if Nat.ltb (S t) (T K)
      then sat K ρ (S t) ψ
      else Some false
  | F_G ψ =>
      let fix go (m:nat) :=
        if Nat.ltb m (T K) then
          match sat K ρ m ψ, go (S m) with
          | Some b1, Some b2 => Some (andb b1 b2)
          | _, _ => None
          end
        else Some true
      in go t
  | F_F ψ =>
      let fix go (m:nat) :=
        if Nat.ltb m (T K) then
          match sat K ρ m ψ, go (S m) with
          | Some b1, Some b2 => Some (orb b1 b2)
          | _, _ => None
          end
        else Some false
      in go t
  | F_U ψ χ =>
      let fix go (m:nat) :=
        if Nat.ltb m (T K) then
          match sat K ρ m χ with
          | Some true => Some true
          | Some false =>
              match sat K ρ m ψ, go (S m) with
              | Some bψ, Some bnext => Some (andb bψ bnext)
              | _, _ => None
              end
          | None => None
          end
        else Some false
      in go t
  end.
