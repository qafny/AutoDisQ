(* finite sets as lists, with decidable equality *)
Definition mem_nat (x:nat) (xs:list nat) : bool :=
  existsb (Nat.eqb x) xs.

Lemma mem_nat_spec : forall x xs, mem_nat x xs = true <-> In x xs.
Proof.
  intros x xs. unfold mem_nat.
  rewrite existsb_exists.
  split.
  - intros [y [Hy Hin]].
    apply Nat.eqb_eq in Hin. subst. exact Hy.
  - intro Hin.
    exists x. split; [exact Hin|]. apply Nat.eqb_refl.
Qed.

