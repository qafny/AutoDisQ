(* parser_csv.ml *)
type row = { t:int; client:int; loss:float; acc:float; part:int }

let split_comma (s:string) : string list =
  let rec go i j acc =
    if j = String.length s then
      List.rev ((String.sub s i (j-i))::acc)
    else if s.[j] = ',' then
      go (j+1) (j+1) ((String.sub s i (j-i))::acc)
    else
      go i (j+1) acc
  in
  go 0 0 []

let read_all_lines (path:string) : string list =
  let ic = open_in path in
  let rec loop acc =
    match input_line ic with
    | line -> loop (line :: acc)
    | exception End_of_file ->
      close_in ic; List.rev acc
  in
  loop []

let parse_row (line:string) : row option =
  match split_comma line with
  | [t; c; loss; acc; part] ->
      (try
         Some {
           t = int_of_string t;
           client = int_of_string c;
           loss = float_of_string loss;
           acc = float_of_string acc;
           part = int_of_string part;
         }
       with _ -> None)
  | _ -> None

let load_csv (path:string) : row list =
  let lines = read_all_lines path in
  match lines with
  | [] -> failwith "Empty CSV"
  | header::rest ->
      (* tolerate header *)
      let rest =
        if String.length header > 0 && String.lowercase_ascii header |> String.trim = "t,client,loss,acc,part"
        then rest else lines
      in
      rest
      |> List.filter_map (fun ln ->
           let ln = String.trim ln in
           if ln = "" then None else parse_row ln)
(* build_trace.ml *)
open Parser_csv

type fstate = {
  loss_of : (int, float) Hashtbl.t;
  acc_of  : (int, float) Hashtbl.t;
  part_of : (int, int) Hashtbl.t;
}

type ftrace = fstate array

let uniq_sorted (xs:int list) : int list =
  xs |> List.sort_uniq compare

let max_int_list (xs:int list) : int =
  List.fold_left max 0 xs

let build (rows:row list) : (int list * ftrace) =
  if rows = [] then failwith "No rows";
  let clients = rows |> List.map (fun r -> r.client) |> uniq_sorted in
  let tmax = rows |> List.map (fun r -> r.t) |> max_int_list in
  let tlen = tmax + 1 in

  let mk_state () =
    { loss_of = Hashtbl.create 32;
      acc_of  = Hashtbl.create 32;
      part_of = Hashtbl.create 32; }
  in
  let trace = Array.init tlen (fun _ -> mk_state ()) in

  List.iter (fun r ->
    let st = trace.(r.t) in
    Hashtbl.replace st.loss_of r.client r.loss;
    Hashtbl.replace st.acc_of  r.client r.acc;
    Hashtbl.replace st.part_of r.client r.part;
  ) rows;

  (* sanity: fill missing entries with defaults *)
  Array.iteri (fun t st ->
    List.iter (fun c ->
      if not (Hashtbl.mem st.loss_of c) then Hashtbl.add st.loss_of c nan;
      if not (Hashtbl.mem st.acc_of c)  then Hashtbl.add st.acc_of c nan;
      if not (Hashtbl.mem st.part_of c) then Hashtbl.add st.part_of c 0;
    ) clients
  ) trace;

  (clients, trace)
