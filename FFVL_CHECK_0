open Unix

let time_it f =
  let t0 = Unix.gettimeofday () in
  let r = f () in
  let t1 = Unix.gettimeofday () in
  (r, t1 -. t0)

(* Evaluator: a simple direct implementation (matches your Coq executable semantics idea).
   For now we check only a useful fragment:
   - G, F, X
   - forall/exists over C
   - boolean connectives
   - atoms Le/Lt/Eq/GapLe with abs
*)

open Formula_parser
open Parser_csv
open Build_trace

type env = (string, int) Hashtbl.t

let env_get rho x =
  match Hashtbl.find_opt rho x with
  | Some v -> v
  | None -> 0

let env_set rho x c =
  let rho' = Hashtbl.copy rho in
  Hashtbl.replace rho' x c;
  rho'

let metric_value (trace:ftrace) (t:int) (client:int) (k:metric_kind) : float option =
  if t < 0 || t >= Array.length trace then None else
  let st = trace.(t) in
  match k with
  | Loss -> Some (Hashtbl.find st.loss_of client)
  | Acc  -> Some (Hashtbl.find st.acc_of  client)
  | Part -> Some (float_of_int (Hashtbl.find st.part_of client))

let rec eval_term (trace:ftrace) (rho:env) (t:int) (e:term) : float option =
  match e with
  | Metric(k,x) ->
      let c = env_get rho x in
      metric_value trace t c k
  | Const r -> Some r
  | Plus(a,b) ->
      begin match eval_term trace rho t a, eval_term trace rho t b with
      | Some x, Some y -> Some (x +. y)
      | _ -> None
      end
  | Minus(a,b) ->
      begin match eval_term trace rho t a, eval_term trace rho t b with
      | Some x, Some y -> Some (x -. y)
      | _ -> None
      end

let rec eval_atom (trace:ftrace) (rho:env) (t:int) (a:atom) : bool option =
  let (<=?) x y = x <= y in
  let (<?) x y = x < y in
  match a with
  | Le(t1,t2) ->
      begin match eval_term trace rho t t1, eval_term trace rho t t2 with
      | Some x, Some y -> Some (<=? x y)
      | _ -> None
      end
  | Lt(t1,t2) ->
      begin match eval_term trace rho t t1, eval_term trace rho t t2 with
      | Some x, Some y -> Some (<? x y)
      | _ -> None
      end
  | Eq(t1,t2) ->
      begin match eval_term trace rho t t1, eval_term trace rho t t2 with
      | Some x, Some y -> Some (x = y)
      | _ -> None
      end
  | GapLe(t1,t2,eps) ->
      begin match eval_term trace rho t t1, eval_term trace rho t t2 with
      | Some x, Some y -> Some (abs_float (x -. y) <= eps)
      | _ -> None
      end

let rec sat (clients:int list) (trace:ftrace) (rho:env) (t:int) (phi:formula) : bool option =
  let tmax = Array.length trace in
  match phi with
  | True -> Some true
  | Atom a -> eval_atom trace rho t a
  | Not p ->
      begin match sat clients trace rho t p with
      | Some b -> Some (not b)
      | None -> None
      end
  | And(p,q) ->
      begin match sat clients trace rho t p, sat clients trace rho t q with
      | Some b1, Some b2 -> Some (b1 && b2)
      | _ -> None
      end
  | Or(p,q) ->
      begin match sat clients trace rho t p, sat clients trace rho t q with
      | Some b1, Some b2 -> Some (b1 || b2)
      | _ -> None
      end
  | Impl(p,q) ->
      begin match sat clients trace rho t p, sat clients trace rho t q with
      | Some b1, Some b2 -> Some ((not b1) || b2)
      | _ -> None
      end
  | Forall(x,p) ->
      let rec all = function
        | [] -> Some true
        | c::tl ->
            begin match sat clients trace (env_set rho x c) t p, all tl with
            | Some b1, Some b2 -> Some (b1 && b2)
            | _ -> None
            end
      in all clients
  | Exists(x,p) ->
      let rec any = function
        | [] -> Some false
        | c::tl ->
            begin match sat clients trace (env_set rho x c) t p, any tl with
            | Some b1, Some b2 -> Some (b1 || b2)
            | _ -> None
            end
      in any clients
  | X p ->
      if t+1 < tmax then sat clients trace rho (t+1) p else Some false
  | G p ->
      let rec go m =
        if m < tmax then
          match sat clients trace rho m p, go (m+1) with
          | Some b1, Some b2 -> Some (b1 && b2)
          | _ -> None
        else Some true
      in go t
  | F p ->
      let rec go m =
        if m < tmax then
          match sat clients trace rho m p, go (m+1) with
          | Some b1, Some b2 -> Some (b1 || b2)
          | _ -> None
        else Some false
      in go t
  | U(p,q) ->
      (* bounded until: exists m >= t s.t. q holds at m and p holds at all k in [t,m) *)
      let rec check_m m =
        if m >= tmax then Some false else
        match sat clients trace rho m q with
        | Some true -> Some true
        | Some false ->
            begin match sat clients trace rho m p, check_m (m+1) with
            | Some bp, Some bnext -> Some (bp && bnext)
            | _ -> None
            end
        | None -> None
      in check_m t

let first_fail (clients:int list) (trace:ftrace) (phi:formula) : int option option =
  let rho0 = Hashtbl.create 8 in
  let rec loop t =
    if t >= Array.length trace then Some None else
    match sat clients trace rho0 t phi with
    | Some true -> loop (t+1)
    | Some false -> Some (Some t)
    | None -> None
  in
  loop 0

let usage () =
  print_endline "Usage: ffvlcheck <log.csv> <formula.ffvl>";
  exit 2

let () =
  if Array.length Sys.argv < 3 then usage ();
  let log_path = Sys.argv.(1) in
  let formula_path = Sys.argv.(2) in

  let rows = Parser_csv.load_csv log_path in
  let (clients, trace) = Build_trace.build rows in
  let fstr = Formula_parser.read_file formula_path in
  let phi = Formula_parser.parse fstr in

  let ((res), secs) =
    time_it (fun () -> first_fail clients trace phi)
  in
  match res with
  | None ->
      Printf.printf "ERROR (evaluation failed). time=%.6fs\n" secs
  | Some None ->
      Printf.printf "OK. time=%.6fs clients=%d rounds=%d\n"
        secs (List.length clients) (Array.length trace)
  | Some (Some t) ->
      Printf.printf "FAIL at t=%d. time=%.6fs clients=%d rounds=%d\n"
        t secs (List.length clients) (Array.length trace)
