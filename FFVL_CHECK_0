From FFVLCheck.src Require Import Base.

Inductive metric_kind := M_loss | M_acc | M_part.

(* A finite trace is a list of "states"; state stores metrics for all clients *)
Record fstate : Type := {
  loss_of : client -> R;
  acc_of  : client -> R;
  part_of : client -> nat
}.

Definition ftrace : Type := list fstate.

Definition trace_len (τ:ftrace) : nat := length τ.

(* access state at time t (option) *)
Fixpoint nth_opt {A} (xs:list A) (n:nat) : option A :=
  match xs,n with
  | [], _ => None
  | x::_ , 0 => Some x
  | _::tl, S k => nth_opt tl k
  end.

Definition metric_at (τ:ftrace) (t:round) (i:client) (k:metric_kind) : option R :=
  match nth_opt τ t with
  | None => None
  | Some s =>
      Some (
        match k with
        | M_loss => loss_of s i
        | M_acc  => acc_of  s i
        | M_part => INR (part_of s i)
        end)
  end.
From Coq Require Import List Arith Lia.
Import ListNotations.
From FFVLCheck.src Require Import Base Metrics.

(* For trace-based checking, the "state space" is indices 0..T-1 *)
Record FKS_trace : Type := {
  Cset : list client;
  C_nonempty : Cset <> [];
  τ : ftrace
}.

Definition T (K:FKS_trace) : nat := trace_len (τ K).

Definition in_time (K:FKS_trace) (t:nat) : Prop := t < T K.

(* step relation: t -> t+1 while in bounds *)
Definition step (K:FKS_trace) (t t':nat) : Prop :=
  t' = S t /\ S t < T K.
