Fixpoint first_fail_from (K:FKS_trace) (ρ:env) (t:nat) (φ:formula) : option nat :=
  if Nat.ltb t (T K) then
    match sat K ρ t φ with
    | Some true => first_fail_from K ρ (S t) φ
    | Some false => Some t
    | None => None
    end
  else None.

Definition check (K:FKS_trace) (φ:formula) : option (bool * option nat) :=
  let ρ0 : env := fun _ => 0%nat in
  match sat K ρ0 0%nat φ with
  | Some true =>
      Some (true, None)
  | Some false =>
      (* find earliest failure location (good “counterexample witness”) *)
      Some (false, first_fail_from K ρ0 0%nat φ)
  | None => None
  end.
