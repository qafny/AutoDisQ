(* formula_parser.ml *)
(* Minimal recursive-descent parser for demo tool usage *)

type var = string

type metric_kind = Loss | Acc | Part

type term =
  | Metric of metric_kind * var
  | Const of float
  | Plus of term * term
  | Minus of term * term

type atom =
  | Le of term * term
  | Lt of term * term
  | Eq of term * term
  | GapLe of term * term * float  (* abs(t1 - t2) <= eps *)

type formula =
  | True
  | Atom of atom
  | Not of formula
  | And of formula * formula
  | Or of formula * formula
  | Impl of formula * formula
  | Forall of var * formula
  | Exists of var * formula
  | X of formula
  | G of formula
  | F of formula
  | U of formula * formula

exception Parse_error of string

let is_space = function ' ' | '\n' | '\t' | '\r' -> true | _ -> false

let tokenize (s:string) : string list =
  let buf = Buffer.create 16 in
  let push acc =
    if Buffer.length buf = 0 then acc
    else
      let tok = Buffer.contents buf in
      Buffer.clear buf;
      tok :: acc
  in
  let rec go i acc =
    if i = String.length s then List.rev (push acc)
    else
      let c = s.[i] in
      if is_space c then go (i+1) (push acc)
      else
        match c with
        | '(' | ')' | '.' | ',' -> go (i+1) (push ((String.make 1 c)::acc))
        | '-' ->
            if i+1 < String.length s && s.[i+1] = '>' then
              go (i+2) (push ("->"::acc))
            else (Buffer.add_char buf c; go (i+1) acc)
        | '<' ->
            if i+1 < String.length s && s.[i+1] = '=' then
              go (i+2) (push ("<="::acc))
            else (Buffer.add_char buf c; go (i+1) acc)
        | _ ->
            Buffer.add_char buf c; go (i+1) acc
  in
  go 0 []

type stream = { toks:string array; mutable i:int }

let peek st = if st.i < Array.length st.toks then Some st.toks.(st.i) else None
let take st = match peek st with Some t -> st.i <- st.i + 1; t | None -> raise (Parse_error "Unexpected EOF")
let expect st x = match peek st with Some t when t = x -> ignore (take st) | _ -> raise (Parse_error ("Expected " ^ x))

let rec parse_formula st = parse_impl st

and parse_impl st =
  let lhs = parse_or st in
  match peek st with
  | Some "->" -> ignore (take st); let rhs = parse_impl st in Impl(lhs, rhs)
  | _ -> lhs

and parse_or st =
  let rec loop acc =
    match peek st with
    | Some "or" -> ignore (take st); let b = parse_and st in loop (Or(acc,b))
    | _ -> acc
  in
  let a = parse_and st in
  loop a

and parse_and st =
  let rec loop acc =
    match peek st with
    | Some "and" -> ignore (take st); let b = parse_unary st in loop (And(acc,b))
    | _ -> acc
  in
  let a = parse_unary st in
  loop a

and parse_unary st =
  match peek st with
  | Some "not" -> ignore (take st); Not (parse_unary st)
  | Some "G" -> ignore (take st); expect st "("; let p = parse_formula st in expect st ")"; G p
  | Some "F" -> ignore (take st); expect st "("; let p = parse_formula st in expect st ")"; F p
  | Some "X" -> ignore (take st); expect st "("; let p = parse_formula st in expect st ")"; X p
  | Some "forall" ->
      ignore (take st);
      let v = take st in
      expect st ".";
      Forall(v, parse_formula st)
  | Some "exists" ->
      ignore (take st);
      let v = take st in
      expect st ".";
      Exists(v, parse_formula st)
  | Some "(" ->
      ignore (take st);
      let p = parse_formula st in
      expect st ")";
      p
  | Some "true" -> ignore (take st); True
  | _ -> Atom (parse_atom st)

and parse_metric_kind = function
  | "loss" -> Loss
  | "acc" -> Acc
  | "part" -> Part
  | x -> raise (Parse_error ("Unknown metric " ^ x))

and parse_term st =
  (* only supports: metric(var) | number | t - t | t + t *)
  let rec parse_factor () =
    match peek st with
    | Some tok when tok = "loss" || tok = "acc" || tok = "part" ->
        let k = parse_metric_kind (take st) in
        expect st "(";
        let v = take st in
        expect st ")";
        Metric(k, v)
    | Some tok ->
        (try Const (float_of_string tok) with _ -> raise (Parse_error ("Bad token in term: " ^ tok)))
        |> fun c -> ignore (take st); c
    | None -> raise (Parse_error "EOF in term")
  in
  let rec parse_sum left =
    match peek st with
    | Some "+" -> ignore (take st); let r = parse_factor () in parse_sum (Plus(left,r))
    | Some "-" -> ignore (take st); let r = parse_factor () in parse_sum (Minus(left,r))
    | _ -> left
  in
  parse_sum (parse_factor ())

and parse_atom st =
  (* supports:
     abs(term - term) <= eps
     term <= term
     term < term
     term = term
  *)
  match peek st with
  | Some "abs" ->
      ignore (take st);
      expect st "(";
      let t1 = parse_term st in
      expect st "-";
      let t2 = parse_term st in
      expect st ")";
      expect st "<=";
      let eps = float_of_string (take st) in
      GapLe(t1,t2,eps)
  | _ ->
      let t1 = parse_term st in
      begin match take st with
      | "<=" -> let t2 = parse_term st in Le(t1,t2)
      | "<"  -> let t2 = parse_term st in Lt(t1,t2)
      | "="  -> let t2 = parse_term st in Eq(t1,t2)
      | op -> raise (Parse_error ("Unknown atom op: " ^ op))
      end

let parse (s:string) : formula =
  let toks = tokenize s |> Array.of_list in
  let st = { toks; i=0 } in
  let f = parse_formula st in
  if st.i <> Array.length st.toks then
    raise (Parse_error "Unconsumed tokens");
  f

let read_file (path:string) : string =
  let ic = open_in path in
  let n = in_channel_length ic in
  let s = really_input_string ic n in
  close_in ic; s


