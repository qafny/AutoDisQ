(* FFVL/Numbers.v *)
From Coq Require Import QArith QArith_base ZArith Bool.

Module Num.

  Definition t := Q.

  Definition le (a b : t) : Prop := (a <= b)%Q.
  Definition lt (a b : t) : Prop := (a < b)%Q.

  Definition leb (a b : t) : bool := Qle_bool a b.
  Definition ltb (a b : t) : bool := Qlt_bool a b.

  Definition sub (a b : t) : t := (a - b)%Q.
  Definition add (a b : t) : t := (a + b)%Q.

  Definition abs (a : t) : t := if Qlt_bool a 0%Q then (-a)%Q else a.

  Lemma leb_spec : forall a b, leb a b = true <-> le a b.
  Proof.
    intros a b; unfold leb, le.
    now rewrite Qle_bool_iff.
  Qed.

  Lemma ltb_spec : forall a b, ltb a b = true <-> lt a b.
  Proof.
    intros a b; unfold ltb, lt.
    now rewrite Qlt_bool_iff.
  Qed.

End Num.

(* FFVL/Kripke.v *)
From Coq Require Import List Bool.
Import ListNotations.

From FFVL Require Import Numbers.
Module K.

  (* You can keep these abstract or instantiate with nat. *)
  Definition Client := nat.
  Definition State  := nat.
  Definition AP     := nat.  (* atomic propositions *)

  (* Finite, nonempty clients set as a list with a proof *)
  Record Clients : Type := {
    clients : list Client;
    clients_nonempty : clients <> []
  }.

  (* Labeling function returns the set of AP true at a state.
     Use list AP for decidable membership (with eqb). *)
  Definition Label := State -> list AP.

  (* Metrics *)
  Definition loss := State -> Client -> Num.t.
  Definition acc  := State -> Client -> Num.t.     (* you can constrain to [0,1] externally *)
  Definition part := State -> Client -> bool.      (* participated? *)

  (* Transition relation: deterministic next-state for executability.
     This implies totality automatically. *)
  Definition Next := State -> State.

  Record FederatedKripke : Type := {
    C    : Clients;
    Smax : nat;            (* finite horizon / max state index you built *)
    s0   : State;
    next : Next;
    APs  : list AP;
    L    : Label;
    Loss : loss;
    Acc  : acc;
    Part : part;

    (* Optional sanity constraints (you can add more): *)
    s0_in_range : s0 <= Smax
  }.

  (* A path is the sequence s0, s1, s2, ... induced by next. *)
  Fixpoint state_at (K : FederatedKripke) (t : nat) : State :=
    match t with
    | 0 => s0 K
    | S t' => next K (state_at K t')
    end.

End K.
(* FFVL/FFVL.v *)
From Coq Require Import List Bool.
Import ListNotations.

From FFVL Require Import Numbers Kripke.
Module F.
  Import K Num.

  (* Terms for metrics *)
  Inductive metric : Type :=
  | MLoss
  | MAcc
  | MPart.  (* bool-valued metric *)

  (* Numeric expressions (only what we need) *)
  Inductive nexpr : Type :=
  | NConst (q : Num.t)
  | NMetric (m : metric) (i : Client).

  (* Boolean expressions over metrics + AP labels *)
  Inductive bexpr : Type :=
  | BTrue
  | BAtom (p : AP)                      (* p ∈ L(s) *)
  | BNot (b : bexpr)
  | BAnd (b1 b2 : bexpr)
  | BOr  (b1 b2 : bexpr)
  | BLe  (e1 e2 : nexpr)                (* e1 ≤ e2 *)
  | BAbsLeLoss (i j : Client) (eps : Num.t)  (* |loss(i)-loss(j)| ≤ eps *)
  | BPartIs (i : Client) (v : bool).    (* part(i)=v *)

  (* Temporal logic with client quantification *)
  Inductive ffvl : Type :=
  | PhiB (b : bexpr)
  | PhiNot (phi : ffvl)
  | PhiAnd (p q : ffvl)
  | PhiOr  (p q : ffvl)
  | X (phi : ffvl)          (* next round *)
  | F (phi : ffvl)          (* eventually *)
  | G (phi : ffvl)          (* always *)
  | U (p q : ffvl)          (* until *)
  | ForallC (phi_of : Client -> ffvl)
  | ExistsC (phi_of : Client -> ffvl).

End F.

(* FFVL/Semantics.v *)
From Coq Require Import List Bool Arith.
Import ListNotations.

From FFVL Require Import Numbers Kripke FFVL.
Module Sem.
  Import K Num F.

  (* membership in labels/APs *)
  Fixpoint memb_ap (a : AP) (xs : list AP) : bool :=
    match xs with
    | [] => false
    | x :: tl => Nat.eqb a x || memb_ap a tl
    end.

  Definition eval_metric (K : FederatedKripke) (t : nat) (m : metric) (i : Client)
    : option Num.t :=
    let s := state_at K t in
    match m with
    | MLoss => Some (Loss K s i)
    | MAcc  => Some (Acc K s i)
    | MPart => None (* boolean-valued; handled separately *)
    end.

  Fixpoint eval_nexpr (K : FederatedKripke) (t : nat) (e : nexpr) : option Num.t :=
    match e with
    | NConst q => Some q
    | NMetric m i => eval_metric K t m i
    end.

  Fixpoint eval_bexpr (K : FederatedKripke) (t : nat) (b : bexpr) : bool :=
    let s := state_at K t in
    match b with
    | BTrue => true
    | BAtom p => memb_ap p (L K s)
    | BNot b1 => negb (eval_bexpr K t b1)
    | BAnd b1 b2 => andb (eval_bexpr K t b1) (eval_bexpr K t b2)
    | BOr  b1 b2 => orb  (eval_bexpr K t b1) (eval_bexpr K t b2)
    | BLe e1 e2 =>
        match eval_nexpr K t e1, eval_nexpr K t e2 with
        | Some v1, Some v2 => Num.leb v1 v2
        | _, _ => false
        end
    | BAbsLeLoss i j eps =>
        let li := Loss K s i in
        let lj := Loss K s j in
        Num.leb (Num.abs (Num.sub li lj)) eps
    | BPartIs i v =>
        Bool.eqb (Part K s i) v
    end.

  (* Iterate over finite client list for quantifiers *)
  Fixpoint forall_clients (cs : list Client) (P : Client -> bool) : bool :=
    match cs with
    | [] => true
    | c :: tl => andb (P c) (forall_clients tl P)
    end.

  Fixpoint exists_clients (cs : list Client) (P : Client -> bool) : bool :=
    match cs with
    | [] => false
    | c :: tl => orb (P c) (exists_clients tl P)
    end.

  (* Bounded satisfaction: checks up to horizon H from time t.
     This is what you use in the executable model checker. *)
  Fixpoint sat_bounded (K : FederatedKripke) (H t : nat) (phi : ffvl) : bool :=
    match H with
    | 0 =>
        (* At horizon 0, only state formulas can be decided "now".
           Temporal operators become conservative (false) except trivial cases. *)
        match phi with
        | PhiB b => eval_bexpr K t b
        | PhiNot p => negb (sat_bounded K 0 t p)
        | PhiAnd p q => andb (sat_bounded K 0 t p) (sat_bounded K 0 t q)
        | PhiOr  p q => orb  (sat_bounded K 0 t p) (sat_bounded K 0 t q)
        | X _ => false
        | F p => sat_bounded K 0 t p
        | G p => sat_bounded K 0 t p
        | U _ _ => false
        | ForallC f =>
            forall_clients (clients (C K)) (fun i => sat_bounded K 0 t (f i))
        | ExistsC f =>
            exists_clients (clients (C K)) (fun i => sat_bounded K 0 t (f i))
        end
    | S H' =>
        match phi with
        | PhiB b => eval_bexpr K t b
        | PhiNot p => negb (sat_bounded K (S H') t p)
        | PhiAnd p q => andb (sat_bounded K (S H') t p) (sat_bounded K (S H') t q)
        | PhiOr  p q => orb  (sat_bounded K (S H') t p) (sat_bounded K (S H') t q)
        | X p => sat_bounded K H' (S t) p
        | F p =>
            (* eventually within H steps: p holds now OR eventually within H' *)
            orb (sat_bounded K H' t p) (sat_bounded K H' (S t) (F p))
        | G p =>
            (* always within H steps: p holds now AND always within H' *)
            andb (sat_bounded K H' t p) (sat_bounded K H' (S t) (G p))
        | U p q =>
            (* p U q within H: q holds now OR (p holds now AND next satisfies U) *)
            orb (sat_bounded K H' t q)
                (andb (sat_bounded K H' t p) (sat_bounded K H' (S t) (U p q)))
        | ForallC f =>
            forall_clients (clients (C K)) (fun i => sat_bounded K (S H') t (f i))
        | ExistsC f =>
            exists_clients (clients (C K)) (fun i => sat_bounded K (S H') t (f i))
        end
    end.

End Sem.
(* FFVL/BMC.v *)
From Coq Require Import List Bool Arith.
Import ListNotations.

From FFVL Require Import Numbers Kripke FFVL Semantics.

Module BMC.
  Import K Num F Sem.

  (* A minimal counterexample object *)
  Record cex : Type := {
    cex_time   : nat;
    cex_client : option Client;
    cex_msg    : nat (* use codes; or switch to string if you prefer *)
  }.

  (* Message codes (simple) *)
  Definition MSG_STATE_FAIL : nat := 1.
  Definition MSG_FORALL_FAIL : nat := 2.
  Definition MSG_G_FAIL : nat := 3.
  Definition MSG_F_FAIL : nat := 4.
  Definition MSG_X_FAIL : nat := 5.
  Definition MSG_U_FAIL : nat := 6.

  Fixpoint find_first_time (K : FederatedKripke) (H t : nat) (phi : ffvl) : option nat :=
    match H with
    | 0 => if sat_bounded K 0 t phi then None else Some t
    | S H' =>
        if sat_bounded K (S H') t phi
        then None
        else
          (* if it fails at t, return t, else search forward (heuristic) *)
          if sat_bounded K H' t phi then find_first_time K H' (S t) phi else Some t
    end.

  Fixpoint find_first_client_fail
    (K : FederatedKripke) (H t : nat) (f : Client -> ffvl) (cs : list Client)
    : option Client :=
    match cs with
    | [] => None
    | c :: tl =>
        if sat_bounded K H t (f c)
        then find_first_client_fail K H t f tl
        else Some c
    end.

  (* Produce a counterexample (best-effort) when check fails. *)
  Fixpoint explain_fail (K : FederatedKripke) (H t : nat) (phi : ffvl) : option cex :=
    match phi with
    | PhiB b =>
        if eval_bexpr K t b then None
        else Some {| cex_time := t; cex_client := None; cex_msg := MSG_STATE_FAIL |}

    | PhiNot p =>
        (* ¬p fails if p holds *)
        if sat_bounded K H t p
        then Some {| cex_time := t; cex_client := None; cex_msg := MSG_STATE_FAIL |}
        else None

    | PhiAnd p q =>
        if sat_bounded K H t p then explain_fail K H t q else explain_fail K H t p

    | PhiOr p q =>
        (* fails if both fail; return one explanation *)
        if sat_bounded K H t p then None
        else if sat_bounded K H t q then None
        else explain_fail K H t p

    | X p =>
        if H =? 0 then Some {| cex_time := t; cex_client := None; cex_msg := MSG_X_FAIL |}
        else explain_fail K (pred H) (S t) p

    | G p =>
        match find_first_time K H t p with
        | None => None
        | Some tf => Some {| cex_time := tf; cex_client := None; cex_msg := MSG_G_FAIL |}
        end

    | F p =>
        (* F fails if p never holds within bound *)
        if sat_bounded K H t (F p)
        then None
        else Some {| cex_time := t; cex_client := None; cex_msg := MSG_F_FAIL |}

    | U p q =>
        if sat_bounded K H t (U p q)
        then None
        else Some {| cex_time := t; cex_client := None; cex_msg := MSG_U_FAIL |}

    | ForallC f =>
        match find_first_client_fail K H t f (clients (C K)) with
        | None => None
        | Some c =>
            (* also try to refine time for that client *)
            Some {| cex_time := t; cex_client := Some c; cex_msg := MSG_FORALL_FAIL |}
        end

    | ExistsC f =>
        (* Exists fails if no client satisfies. *)
        if sat_bounded K H t (ExistsC f)
        then None
        else Some {| cex_time := t; cex_client := None; cex_msg := MSG_STATE_FAIL |}
    end.

  Definition check (K : FederatedKripke) (H : nat) (phi : ffvl) : bool :=
    sat_bounded K H 0 phi.

  Definition check_with_cex (K : FederatedKripke) (H : nat) (phi : ffvl)
    : bool * option cex :=
    let ok := check K H phi in
    if ok then (true, None) else (false, explain_fail K H 0 phi).

End BMC.
Module Example2.
  Import K Num F.

  Definition theta : Num.t := (9#10)%Q. (* 0.9 *)

  Definition eventual_acc_ge (i : Client) : ffvl :=
    F (PhiB (BLe (NConst theta) (NMetric MAcc i))).  (* theta ≤ acc(i) *)

  Definition eventual_accuracy_for_all : ffvl :=
    ForallC eventual_acc_ge.
End Example2.
Module Instantiation.
  Import K Num F Sem BMC.

  Definition C_list : list Client := [0;1;2].  (* three clients *)
  Lemma C_nonempty : C_list <> [].
  Proof. discriminate. Qed.

  Definition C0 : Clients := {| clients := C_list; clients_nonempty := C_nonempty |}.

  Definition Smax0 : nat := 100.

  Definition next0 (s : State) : State :=
    if Nat.leb s Smax0 then S s else s.

  (* Replace these with your real logs (arrays, maps, etc.) *)
  Definition Loss0 (s : State) (i : Client) : Num.t := (0#1)%Q.
  Definition Acc0  (s : State) (i : Client) : Num.t := (0#1)%Q.
  Definition Part0 (s : State) (i : Client) : bool := true.

  Definition L0 (s : State) : list AP := [].

  Lemma s0_ok : 0 <= Smax0. Proof. auto. Qed.

  Definition K0 : FederatedKripke :=
    {| C := C0; Smax := Smax0; s0 := 0;
       next := next0; APs := []; L := L0;
       Loss := Loss0; Acc := Acc0; Part := Part0;
       s0_in_range := s0_ok |}.

End Instantiation.
(* FFVL/Theorems.v *)
From Coq Require Import List Bool Arith Lia.
Import ListNotations.

From FFVL Require Import Numbers Kripke FFVL Semantics BMC.

Module Theorems.
  Import Num K F Sem BMC.

  (* ======================================================= *)
  (* Helpers: AP membership soundness                         *)
  (* ======================================================= *)

  Fixpoint In_ap (a : AP) (xs : list AP) : Prop :=
    match xs with
    | [] => False
    | x :: tl => x = a \/ In_ap a tl
    end.

  Lemma memb_ap_sound : forall a xs,
    memb_ap a xs = true -> In_ap a xs.
  Proof.
    intros a xs; induction xs as [|x tl IH]; simpl; intros H.
    - discriminate.
    - apply orb_true_iff in H. destruct H as [H|H].
      + left. apply Nat.eqb_eq in H. symmetry. exact H.
      + right. apply IH. exact H.
  Qed.

  (* Optional completeness (sometimes useful) *)
  Lemma memb_ap_complete : forall a xs,
    In_ap a xs -> memb_ap a xs = true.
  Proof.
    intros a xs; induction xs as [|x tl IH]; simpl; intros H.
    - contradiction.
    - destruct H as [H|H].
      + subst. rewrite Nat.eqb_refl. simpl. reflexivity.
      + apply orb_true_iff. right. apply IH. exact H.
  Qed.

  (* ======================================================= *)
  (* (A) Prop semantics for nexpr/bexpr + soundness           *)
  (* ======================================================= *)

  (* Prop-eval for nexpr *)
  Inductive nexpr_denote (K : FederatedKripke) (t : nat) : nexpr -> Num.t -> Prop :=
  | DNConst : forall q, nexpr_denote K t (NConst q) q
  | DNMetricLoss : forall i,
      nexpr_denote K t (NMetric MLoss i) (Loss K (state_at K t) i)
  | DNMetricAcc : forall i,
      nexpr_denote K t (NMetric MAcc i) (Acc K (state_at K t) i).

  (* Prop semantics for bexpr at time t *)
  Inductive bexpr_holds (K : FederatedKripke) (t : nat) : bexpr -> Prop :=
  | BHTrue : bexpr_holds K t BTrue
  | BHAtom : forall p,
      In_ap p (L K (state_at K t)) ->
      bexpr_holds K t (BAtom p)
  | BHNot : forall b,
      ~ bexpr_holds K t b ->
      bexpr_holds K t (BNot b)
  | BHAnd : forall b1 b2,
      bexpr_holds K t b1 ->
      bexpr_holds K t b2 ->
      bexpr_holds K t (BAnd b1 b2)
  | BHOrL : forall b1 b2,
      bexpr_holds K t b1 ->
      bexpr_holds K t (BOr b1 b2)
  | BHOrR : forall b1 b2,
      bexpr_holds K t b2 ->
      bexpr_holds K t (BOr b1 b2)
  | BHLe : forall e1 e2 v1 v2,
      nexpr_denote K t e1 v1 ->
      nexpr_denote K t e2 v2 ->
      Num.le v1 v2 ->
      bexpr_holds K t (BLe e1 e2)
  | BHAbsLeLoss : forall i j eps,
      Num.le (Num.abs (Num.sub (Loss K (state_at K t) i)
                                (Loss K (state_at K t) j))) eps ->
      bexpr_holds K t (BAbsLeLoss i j eps)
  | BHPartIs : forall i v,
      Part K (state_at K t) i = v ->
      bexpr_holds K t (BPartIs i v).

  (* Relate eval_nexpr (option) to denotation *)
  Lemma eval_nexpr_sound :
    forall (K : FederatedKripke) t e v,
      eval_nexpr K t e = Some v ->
      nexpr_denote K t e v.
  Proof.
    intros K0 t e; destruct e; simpl; intros v H.
    - inversion H; subst. constructor.
    - destruct m; simpl in H.
      + inversion H; subst. constructor.
      + inversion H; subst. constructor.
      + (* MPart returns None for eval_metric -> contradiction *)
        discriminate.
  Qed.

  (* (A) Soundness of boolean evaluator: if it returns true, Prop holds *)
  Theorem eval_bexpr_sound :
    forall (K : FederatedKripke) t b,
      eval_bexpr K t b = true ->
      bexpr_holds K t b.
  Proof.
    intros K0 t b; revert t.
    induction b; intros t Hb; simpl in Hb.
    - constructor.
    - apply memb_ap_sound in Hb. constructor. exact Hb.
    - (* not *)
      apply negb_true_iff in Hb.
      apply BHNot. intro Hholds.
      (* use IH to show eval_bexpr = true if holds; we only have soundness.
         So prove contrapositive with a small lemma: holds -> eval=true is not available.
         Instead, we can use classical reasoning:
         For this theorem, we only need: eval(Not b)=true means eval(b)=false,
         and from soundness of b we can't derive ~holds directly.
         So: we strengthen by proving soundness for this inductive form using
         decidable semantics would require completeness too.

         Practical fix: state (A) for the fragment without BHNot,
         OR add a completeness lemma. We'll add completeness for bexpr below,
         then use it here. *)
      admit.
    - (* and *)
      apply andb_true_iff in Hb. destruct Hb as [H1 H2].
      constructor; [apply IHb1|apply IHb2]; assumption.
    - (* or *)
      apply orb_true_iff in Hb. destruct Hb as [H|H].
      + apply BHOrL. apply IHb1. exact H.
      + apply BHOrR. apply IHb2. exact H.
    - (* ≤ *)
      destruct (eval_nexpr K0 t n) eqn:E1; try discriminate.
      destruct (eval_nexpr K0 t n0) eqn:E2; try discriminate.
      eapply BHLe.
      + eapply eval_nexpr_sound. eauto.
      + eapply eval_nexpr_sound. eauto.
      + apply Num.leb_spec. exact Hb.
    - (* |loss-loss| ≤ eps *)
      eapply BHAbsLeLoss.
      apply Num.leb_spec. exact Hb.
    - (* part(i)=v *)
      apply Bool.eqb_true_iff in Hb.
      constructor. exact Hb.
  Admitted.

  (*
    IMPORTANT:
    The only admitted part above is the BHNot case.
    To fully close it, you need completeness:
      bexpr_holds -> eval_bexpr = true
    so you can prove eval(Not b)=true implies ~holds(b).
    I include the completeness theorem below and then you can replace "admit"
    with a short proof using it.
  *)

  (* Completeness: Prop holds -> eval_bexpr = true (for executable, decidable bexpr) *)
  Theorem eval_bexpr_complete :
    forall (K : FederatedKripke) t b,
      bexpr_holds K t b ->
      eval_bexpr K t b = true.
  Proof.
    intros K0 t b H; induction H; simpl.
    - reflexivity.
    - apply memb_ap_complete; assumption.
    - (* not *) apply negb_true_iff. (* need eval(b)=false *)
      (* from ~holds b and completeness contrapositive is nontrivial.
         If you want a fully constructive completeness, define bexpr_holds
         using boolean semantics itself or require decidability lemma for holds.
         In practice, we usually prove equivalence:
           eval_bexpr = true <-> holds_bool = true
         and define holds_prop as holds_bool = true.
       *)
      admit.
    - rewrite IHbexpr_holds1, IHbexpr_holds2; reflexivity.
    - rewrite IHbexpr_holds; apply orb_true_iff; left; reflexivity.
    - rewrite IHbexpr_holds; apply orb_true_iff; right; reflexivity.
    - (* le *)
      (* build eval_nexpr = Some v1/v2 is true by construction of denotation; omitted *)
      admit.
    - (* absleloss *)
      apply Num.leb_spec. assumption.
    - (* part *)
      subst. apply Bool.eqb_true_iff. reflexivity.
  Admitted.

  (*
    Practical recommendation:
    To avoid classical/constructive pain for Not/completeness,
    define Prop semantics as:
      bexpr_holds K t b := eval_bexpr K t b = true
    Then (A) becomes trivial and fully executable.
    If you want, I can rewrite Semantics.v accordingly so all theorems close cleanly.
  *)

  (* ======================================================= *)
  (* (B) Bounded soundness: check=true => Prop bounded holds  *)
  (* ======================================================= *)

  (* Prop semantics for bounded satisfaction (mirrors sat_bounded) *)
  Fixpoint satP_bounded (K : FederatedKripke) (H t : nat) (phi : ffvl) : Prop :=
    match H with
    | 0 =>
        match phi with
        | PhiB b => bexpr_holds K t b
        | PhiNot p => ~ satP_bounded K 0 t p
        | PhiAnd p q => satP_bounded K 0 t p /\ satP_bounded K 0 t q
        | PhiOr p q => satP_bounded K 0 t p \/ satP_bounded K 0 t q
        | X _ => False
        | F p => satP_bounded K 0 t p
        | G p => satP_bounded K 0 t p
        | U _ _ => False
        | ForallC f => Forall (fun i => satP_bounded K 0 t (f i)) (clients (C K))
        | ExistsC f => Exists (fun i => satP_bounded K 0 t (f i)) (clients (C K))
        end
    | S H' =>
        match phi with
        | PhiB b => bexpr_holds K t b
        | PhiNot p => ~ satP_bounded K (S H') t p
        | PhiAnd p q => satP_bounded K (S H') t p /\ satP_bounded K (S H') t q
        | PhiOr p q => satP_bounded K (S H') t p \/ satP_bounded K (S H') t q
        | X p => satP_bounded K H' (S t) p
        | F p => satP_bounded K H' t p \/ satP_bounded K H' (S t) (F p)
        | G p => satP_bounded K H' t p /\ satP_bounded K H' (S t) (G p)
        | U p q => satP_bounded K H' t q \/ (satP_bounded K H' t p /\ satP_bounded K H' (S t) (U p q))
        | ForallC f => Forall (fun i => satP_bounded K (S H') t (f i)) (clients (C K))
        | ExistsC f => Exists (fun i => satP_bounded K (S H') t (f i)) (clients (C K))
        end
    end.

  (* List Forall/Exists helpers to connect with bool forall_clients/exists_clients *)
  Lemma forall_clients_sound :
    forall cs P,
      forall_clients cs P = true ->
      Forall (fun c => P c = true) cs.
  Proof.
    induction cs as [|c tl IH]; simpl; intros P H.
    - constructor.
    - apply andb_true_iff in H. destruct H as [Hc Htl].
      constructor; [exact Hc|].
      apply IH; exact Htl.
  Qed.

  Lemma exists_clients_sound :
    forall cs P,
      exists_clients cs P = true ->
      Exists (fun c => P c = true) cs.
  Proof.
    induction cs as [|c tl IH]; simpl; intros P H.
    - discriminate.
    - apply orb_true_iff in H. destruct H as [Hc|Htl].
      + constructor 1. exact Hc.
      + constructor 2. apply IH. exact Htl.
  Qed.

  (* (B) Soundness of bounded checker: sat_bounded=true => satP_bounded *)
  Theorem sat_bounded_sound :
    forall K H t phi,
      sat_bounded K H t phi = true ->
      satP_bounded K H t phi.
  Proof.
    intros K0 H; induction H as [|H' IH]; intros t phi Hsat;
      destruct phi; simpl in Hsat; simpl.
    - (* PhiB *) apply eval_bexpr_sound; exact Hsat.
    - (* Not *) apply negb_true_iff in Hsat. intro HP. (* need completeness to close *)
      admit.
    - (* And *) apply andb_true_iff in Hsat. tauto using IH.
    - (* Or  *) apply orb_true_iff in Hsat. destruct Hsat; [left|right]; eauto using IH.
    - (* X *) discriminate.
    - (* F *) exact (IH t f Hsat).
    - (* G *) exact (IH t f Hsat).
    - (* U *) discriminate.
    - (* ForallC *) 
      apply forall_clients_sound in Hsat.
      (* convert Forall of (P c=true) into Forall of satP *)
      induction Hsat; constructor.
      + apply IH with (t:=t). exact H.
      + exact IHHsat.
    - (* ExistsC *)
      apply exists_clients_sound in Hsat.
      induction Hsat.
      + constructor 1. apply IH with (t:=t). exact H.
      + constructor 2. exact IHHsat.

    (* H = S H' cases *)
    - (* PhiB *) apply eval_bexpr_sound; exact Hsat.
    - (* Not *) intro HP. (* as above, needs completeness or definitional holds=eval=true *)
      admit.
    - (* And *) apply andb_true_iff in Hsat. destruct Hsat. split; eauto.
    - (* Or *) apply orb_true_iff in Hsat. destruct Hsat; [left|right]; eauto.
    - (* X *) apply IH with (t:=S t). exact Hsat.
    - (* F *) apply orb_true_iff in Hsat. destruct Hsat; [left|right]; eauto.
    - (* G *) apply andb_true_iff in Hsat. destruct Hsat as [Hnow Hlater].
      split; [eapply IH; eauto|].
      (* G continues with same (S H') bound from (S t); use IH on (G f) *)
      eapply IH with (t:=S t). exact Hlater.
    - (* U *) apply orb_true_iff in Hsat. destruct Hsat as [Hq|Hp].
      + left. eapply IH. exact Hq.
      + apply andb_true_iff in Hp. destruct Hp as [Hpnow Hnext].
        right. split; [eapply IH; eauto|].
        eapply IH with (t:=S t). exact Hnext.
    - (* ForallC *)
      apply forall_clients_sound in Hsat.
      induction Hsat; constructor.
      + eapply IH. exact H.
      + exact IHHsat.
    - (* ExistsC *)
      apply exists_clients_sound in Hsat.
      induction Hsat.
      + constructor 1. eapply IH. exact H.
      + constructor 2. exact IHHsat.
  Admitted.

  (* (B) statement in terms of check *)
  Theorem check_bounded_sound :
    forall (K : FederatedKripke) (H : nat) (phi : ffvl),
      check K H phi = true ->
      satP_bounded K H 0 phi.
  Proof.
    unfold check.
    intros; eapply sat_bounded_sound; eauto.
  Qed.

  (* ======================================================= *)
  (* (C) Counterexample witness for bounded failures          *)
  (* ======================================================= *)

  (* Witness for ALWAYS (G): if G fails within bound H, find first time <=H where it fails *)
  Fixpoint first_fail_time_G (K : FederatedKripke) (H t : nat) (p : ffvl) : option nat :=
    match H with
    | 0 => if sat_bounded K 0 t p then None else Some t
    | S H' =>
        if sat_bounded K H' t p
        then first_fail_time_G K H' (S t) p
        else Some t
    end.

  Lemma first_fail_time_G_sound :
    forall K H t p tf,
      first_fail_time_G K H t p = Some tf ->
      tf >= t /\ tf <= t + H /\
      sat_bounded K (t + H - tf) tf p = false.
  Proof.
    intros K0 H; induction H as [|H' IH]; intros t p tf Hff; simpl in Hff.
    - destruct (sat_bounded K0 0 t p) eqn:E; try discriminate.
      inversion Hff; subst tf.
      split; [lia|]. split; [lia|].
      (* remaining bound = 0 *)
      simpl. rewrite E. reflexivity.
    - destruct (sat_bounded K0 H' t p) eqn:E.
      + (* it held at t under H' -> recur *)
        specialize (IH (S t) p tf Hff).
        destruct IH as [H1 [H2 H3]].
        split; [lia|]. split; [lia|].
        (* adjust remaining bound; we don't need a tight formula here in practice *)
        exact H3.
      + inversion Hff; subst tf.
        split; [lia|]. split; [lia|].
        (* show p fails at t with some remaining bound; at least H' is fine *)
        (* Here sat_bounded K0 H' t p = false. *)
        (* remaining bound is (t + S H' - t)=S H' *)
        assert (t + S H' - t = S H') by lia.
        rewrite H. rewrite E. reflexivity.
  Qed.

  (* (C1) For G-properties: if check fails, there exists a time <=H where inner fails *)
  Theorem counterexample_time_for_G :
    forall (K : FederatedKripke) (H : nat) (p : ffvl),
      check K H (G p) = false ->
      exists tf,
        tf <= H /\
        sat_bounded K (H - tf) tf p = false.
  Proof.
    intros K0 H p Hfail.
    unfold check in Hfail.
    (* sat_bounded K H 0 (G p) = false implies first_fail_time_G finds something *)
    (* We use a classical/constructive shortcut: define tf by searching. *)
    remember (first_fail_time_G K0 H 0 p) as opt.
    destruct opt as [tf|].
    - exists tf.
      subst.
      pose proof (first_fail_time_G_sound K0 H 0 p tf eq_refl) as [A [B C]].
      (* B gives tf <= 0 + H *)
      split; [lia|].
      (* C already provides sat_bounded ... = false (with some remaining bound) *)
      (* In our statement remaining bound is (H - tf). *)
      (* From C we have bound (0+H-tf)=H-tf *)
      simpl in C. exact C.
    - (* If None, then p holds at all times within bound -> G would be true, contradiction *)
      (* This proof is longer; you can avoid it by defining check for G using first_fail_time_G directly. *)
      exfalso. admit.
  Admitted.

  (* (C2) For forall-client properties: if it fails, there exists a client that fails *)
  Theorem counterexample_client_for_Forall :
    forall (K : FederatedKripke) (H t : nat) (f : Client -> ffvl),
      sat_bounded K H t (ForallC f) = false ->
      exists c, In c (clients (C K)) /\ sat_bounded K H t (f c) = false.
  Proof.
    intros K0 H t f Hfail.
    unfold sat_bounded in Hfail.
    (* unfold sat_bounded’s ForallC case: it's forall_clients ... *)
    (* We need the contrapositive of forall_clients_sound, so we prove a direct lemma *)
    revert Hfail.
    generalize (clients (C K0)) as cs.
    induction cs as [|c tl IH]; simpl; intros Hfail.
    - (* empty list can't happen in well-formed Clients, but list could be empty here only if violated invariant *)
      (* still, handle *)
      discriminate.
    - (* forall_clients (c::tl) P = andb (P c) (forall_clients tl P) *)
      (* If it's false, then P c=false or tail=false *)
      apply andb_false_iff in Hfail.
      destruct Hfail as [Hc | Htl].
      + exists c. split.
        * simpl; auto.
        * exact Hc.
      + specialize (IH Htl). destruct IH as [c' [Hin Hsat]].
        exists c'. split.
        * simpl; auto.
        * exact Hsat.
  Qed.

End Theorems.
Definition bexpr_holds (K) (t) (b) : Prop := eval_bexpr K t b = true.

